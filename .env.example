# ivrit_agent transcription service — environment variables.
# Every value below is the DEFAULT (matches resource/main.py); the app runs
# with zero env vars set. Copy to `.env` and edit to override.

# Whisper model id (ctranslate2 / faster-whisper format).
WHISPER_MODEL=ivrit-ai/whisper-large-v3-turbo-ct2
# Compute device: cpu or cuda.
DEVICE=cpu
# whisperx compute type (int8 keeps CPU memory/latency low).
COMPUTE_TYPE=int8
# Transcription language (ISO code); he = Hebrew.
LANGUAGE=he
# Local pyannote diarization config; relative paths resolve against the repo root.
DIARIZATION_CONFIG=models/pyannote-diarization/config.yaml
# Minimum number of speakers the diarizer should assume.
MIN_SPEAKERS=2
# Batch size passed to model.transcribe().
BATCH_SIZE=4
# Reject uploads larger than this many bytes (default 25 MiB).
MAX_UPLOAD_BYTES=26214400
# uvicorn bind host.
HOST=0.0.0.0
# uvicorn bind port.
PORT=8000
# Force Hugging Face libraries offline (1 = offline). Exported at import time.
HF_HUB_OFFLINE=1
